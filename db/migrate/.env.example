# Copy to .env.migrate (or export) and fill real values.
# Target unified Postgres (create the DB first if needed)
UNIFIED_DATABASE_URL=postgres://postgres:YOURSTRONGPASS@80.208.224.130:5432/omnibox

# Sources (only set the ones you want to backfill)
# Telegram: path to its SQLite (the real one on the machine or copied)
TG_SQLITE_PATH=/path/to/telegram_portal.db

# Discord (tenant_main.* lives here)
DISCORD_DATABASE_URL=postgres://discord_unibox:pass@host:5432/discord_unibox

# TikTok (direct or via its postgres; or build the connection from supabase url+key if you prefer)
TIKTOK_DATABASE_URL=postgres://tiktok_user:pass@host:5432/tiktok

# Optional: the operator row that will own all platform_accounts
UNIFIED_OPERATOR_EMAIL=you@yourdomain.com
UNIFIED_OPERATOR_NAME="Main Operator"
