APP_HOST=staging.droply.click
FRONTEND_IMAGE=tg-saas-frontend-staging
BACKEND_IMAGE=tg-saas-backend-staging

TRAEFIK_DOCKER_NETWORK=coolify
TRAEFIK_CERT_RESOLVER=letsencrypt
TRAEFIK_UI_HTTP_ROUTER=droply-staging-ui-http
TRAEFIK_UI_HTTPS_ROUTER=droply-staging-ui-https
TRAEFIK_UI_SERVICE=droply-staging-ui-svc
TRAEFIK_API_HTTP_ROUTER=droply-staging-api-http
TRAEFIK_API_HTTPS_ROUTER=droply-staging-api-https
TRAEFIK_API_SERVICE=droply-staging-api-svc

SUPABASE_DOCKER_NETWORK=supabase_staging_default
SUPABASE_URL=http://supabase-kong:8000
SUPABASE_SERVICE_KEY=replace-with-staging-service-role-key

STAGING_DISABLE_AUTOMATION=true
